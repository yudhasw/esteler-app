# =============================================
# Database - Neon PostgreSQL
# PENTING: gunakan POOLED connection string!
# Format: postgresql://user:pass@HOST-pooler.region.aws.neon.tech/db?sslmode=require
# Cari di Neon dashboard -> Connection String -> pilih "Pooled connection"
# =============================================
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dapur_hijrah?sslmode=require

# =============================================
# Security - WAJIB di-set di production!
# Generate random string: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================
SECRET_KEY=ganti-dengan-random-string-yang-panjang-dan-aman

# =============================================
# Flask Environment
# =============================================
FLASK_ENV=development

# =============================================
# Cloudinary - upload gambar menu (free tier)
# Daftar di https://cloudinary.com lalu lihat Dashboard -> Product Environment Credentials
# =============================================
CLOUDINARY_CLOUD_NAME=ganti-dengan-cloud-name
CLOUDINARY_API_KEY=ganti-dengan-api-key
CLOUDINARY_API_SECRET=ganti-dengan-api-secret

# =============================================
# Groq - LLM untuk chatbot (gratis, daftar di https://console.groq.com)
# =============================================
GROQ_API_KEY=ganti-dengan-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
